<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luxury Watch</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:sans-serif;
}

body{
background:#0a0a0a;
color:white;
}

.hero{
height:100vh;
background:url("https://images.unsplash.com/photo-1523170335258-f5ed11844a49?w=1600") center/cover;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
}

.overlay{
background:rgba(0,0,0,.55);
padding:50px;
border-radius:15px;
}

h1{
font-size:60px;
margin-bottom:15px;
}

p{
color:#ddd;
}

.btn{
display:inline-block;
margin-top:20px;
padding:12px 30px;
background:#c8a96b;
color:black;
text-decoration:none;
font-weight:bold;
border-radius:8px;
}

.products{
padding:80px 10%;
}

.products h2{
text-align:center;
margin-bottom:40px;
font-size:40px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.card{
background:#161616;
border-radius:15px;
overflow:hidden;
}

.card img{
width:100%;
height:280px;
object-fit:cover;
}

.card-content{
padding:20px;
}

.price{
color:#c8a96b;
font-size:22px;
margin-top:10px;
}

footer{
text-align:center;
padding:30px;
border-top:1px solid #222;
}
</style>

</head>
<body>

<section class="hero">
<div class="overlay">
<h1>LUXURY WATCHES</h1>
<p>Timeless Elegance</p>
<a href="#shop" class="btn">Explore Collection</a>
</div>
</section>

<section class="products" id="shop">
<h2>Featured Watches</h2>

<div class="grid">

<div class="card">
<img src="https://images.unsplash.com/photo-1547996160-81dfa63595aa?w=800">
<div class="card-content">
<h3>Classic Gold</h3>
<div class="price">$750</div>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1522312346375-d1a52e2b99b3?w=800">
<div class="card-content">
<h3>Royal Black</h3>
<div class="price">$920</div>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1434056886845-dac89ffe9b56?w=800">
<div class="card-content">
<h3>Silver Edition</h3>
<div class="price">$680</div>
</div>
</div>

</div>
</section>

<footer>
© 2026 Luxury Watches
</footer>

</body>
</html>
